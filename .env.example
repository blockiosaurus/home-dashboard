# Family Dashboard — environment variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# .env is gitignored so secrets stay local. The server loads this file at
# startup (see packages/server/src/env.ts). systemd's EnvironmentFile= and
# any pre-existing process env always win over .env values.

# ---------------------------------------------------------------------------
# Google OAuth (required for Calendar two-way sync and Photos slideshow)
#
# Create a "TVs and Limited Input devices" OAuth client at
# https://console.cloud.google.com/apis/credentials and paste both values
# below. Make sure these APIs are enabled in the same project:
#   - Google Calendar API
#   - Photos Library API
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Server (optional — defaults shown)
# ---------------------------------------------------------------------------
# PORT=3000
# HOST=0.0.0.0
# DATA_DIR=./data
