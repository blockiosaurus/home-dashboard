# Rotate touchscreen coordinates to match the display rotation set by
# cage-rotated (--transform 90 by default). Without this the display
# renders rotated but touch points come in at native orientation, so
# every tap is in the wrong place.
#
# Matrices (per libinput docs):
#   90° CW   : "0 -1 1  1 0 0"
#   180°     : "-1 0 1  0 -1 1"
#   270° CW  : "0 1 0  -1 0 1"
#
# Change the matrix below if you set CAGE_TRANSFORM to something other than 90.
ACTION=="add|change", KERNEL=="event[0-9]*", ENV{ID_INPUT_TOUCHSCREEN}=="1", \
  ENV{LIBINPUT_CALIBRATION_MATRIX}="0 -1 1 1 0 0"
